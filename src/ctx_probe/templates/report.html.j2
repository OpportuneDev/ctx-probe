<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>ctx-probe report · {{ model }}</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  :root { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; }
  body { max-width: 960px; margin: 2rem auto; padding: 0 1rem; color: #1a1a1a; }
  h1 { font-size: 1.6rem; margin: 0 0 0.5rem; }
  h2 { font-size: 1.15rem; margin: 2rem 0 0.75rem; }
  .meta { color: #555; font-size: 0.9rem; margin-bottom: 1.5rem; }
  .meta code { background: #f3f3f3; padding: 0.1rem 0.35rem; border-radius: 3px; }
  table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  th, td { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 1px solid #eee; }
  th { background: #fafafa; font-weight: 600; }
  .chart-wrap { padding: 1rem; border: 1px solid #eee; border-radius: 6px; background: #fff; }
  .footer { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid #eee; color: #555; font-size: 0.9rem; }
  .footer a { color: #1a1a1a; }
  .num { font-variant-numeric: tabular-nums; }
</style>
</head>
<body>

<h1>Effective context probe · {{ model }}</h1>
<div class="meta">
  Run at <code>{{ started_at }}</code> · target context <code>{{ target_tokens }}</code> tokens ·
  {{ total_calls }} model calls
</div>

<h2>Accuracy vs. context depth</h2>
<div class="chart-wrap">
  <canvas id="curve" height="120"></canvas>
</div>

<h2>Summary</h2>
<table>
  <thead>
    <tr>
      <th>Probe</th>
      <th class="num">Calls</th>
      <th class="num">Accuracy</th>
      <th class="num">Avg input tokens</th>
      <th class="num">Cache hit rate</th>
      <th class="num">Avg latency (ms)</th>
    </tr>
  </thead>
  <tbody>
    {% for row in summary_rows %}
    <tr>
      <td>{{ row.probe }}</td>
      <td class="num">{{ row.calls }}</td>
      <td class="num">{{ "%.1f"|format(row.accuracy * 100) }}%</td>
      <td class="num">{{ "{:,}".format(row.avg_input_tokens) }}</td>
      <td class="num">{{ "%.1f"|format(row.cache_hit_rate * 100) }}%</td>
      <td class="num">{{ "%.0f"|format(row.avg_latency_ms) }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>

{% if failures %}
<h2>Sample failures ({{ failures|length }})</h2>
<table>
  <thead><tr><th>Probe</th><th class="num">Depth</th><th>Expected</th><th>Response</th></tr></thead>
  <tbody>
    {% for f in failures %}
    <tr>
      <td>{{ f.probe }}</td>
      <td class="num">{{ "%.2f"|format(f.depth) }}</td>
      <td><code>{{ f.expected }}</code></td>
      <td>{{ f.response_text[:180] }}{% if f.response_text|length > 180 %}…{% endif %}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

<div class="footer">
  Built by <a href="https://opportunedev.com">Opportune</a>.
  Confused by this curve, or want help acting on it?
  <a href="https://opportunedev.com/#services">Book 20 minutes</a>.
</div>

<script>
const chartData = {{ chart_data_json|safe }};
const ctx = document.getElementById('curve').getContext('2d');
new Chart(ctx, {
  type: 'line',
  data: {
    labels: chartData.labels,
    datasets: chartData.datasets.map((ds, i) => ({
      label: ds.label,
      data: ds.data,
      borderColor: ['#1f77b4', '#ff7f0e', '#2ca02c', '#d62728', '#9467bd'][i % 5],
      backgroundColor: 'transparent',
      tension: 0.2,
      pointRadius: 4,
    })),
  },
  options: {
    responsive: true,
    scales: {
      y: { min: 0, max: 1, title: { display: true, text: 'Accuracy' },
           ticks: { callback: v => (v * 100).toFixed(0) + '%' } },
      x: { title: { display: true, text: 'Needle depth in context' },
           ticks: { callback: function(v) { return (this.getLabelForValue(v) * 100).toFixed(0) + '%'; } } },
    },
    plugins: { legend: { position: 'bottom' } },
  },
});
</script>
</body>
</html>
